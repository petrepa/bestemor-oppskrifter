---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RecipeCard from '../../components/RecipeCard.astro';
import { getCollection } from 'astro:content';

const oppskrifter = await getCollection('oppskrifter');
const sorted = oppskrifter.sort(
  (a, b) => new Date(b.data.dato).getTime() - new Date(a.data.dato).getTime()
);

const allTags = [...new Set(oppskrifter.flatMap((r) => r.data.tags))].sort();
---

<BaseLayout title="Alle oppskrifter">
  <h1>Alle oppskrifter</h1>
  <p class="page-intro">Her finn du alle oppskriftene i samlinga.</p>

  <div class="filter-tags">
    {
      allTags.map((tag) => (
        <a href={`${import.meta.env.BASE_URL}/taggar/${tag}/`} class="filter-tag">
          {tag}
        </a>
      ))
    }
  </div>

  <div class="recipes-grid">
    {
      sorted.map((recipe) => (
        <RecipeCard
          tittel={recipe.data.tittel}
          slug={recipe.id}
          kategori={recipe.data.kategori}
          tags={recipe.data.tags}
        />
      ))
    }
  </div>
</BaseLayout>

<style>
  h1 {
    margin-bottom: 0.25rem;
  }

  .page-intro {
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }

  .filter-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .filter-tag {
    font-size: 0.85rem;
    background: rgba(138, 158, 122, 0.15);
    color: var(--color-green-hover);
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    transition:
      background 0.2s,
      color 0.2s;
  }

  .filter-tag:hover {
    background: var(--color-green);
    color: white;
  }

  .recipes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }
</style>
