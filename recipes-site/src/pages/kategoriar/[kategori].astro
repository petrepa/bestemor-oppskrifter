---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RecipeCard from '../../components/RecipeCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const oppskrifter = await getCollection('oppskrifter');
  const kategoriar = [...new Set(oppskrifter.map((r) => r.data.kategori))];
  return kategoriar.map((kategori) => ({
    params: { kategori: kategori.toLowerCase().replace(/\s+/g, '-') },
    props: {
      kategori,
      recipes: oppskrifter.filter((r) => r.data.kategori === kategori),
    },
  }));
}

const { kategori, recipes } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={kategori}>
  <a href={`${base}/kategoriar/`} class="back">&larr; Alle kategoriar</a>
  <h1>{kategori}</h1>
  <p class="count">
    {recipes.length}
    {recipes.length === 1 ? 'oppskrift' : 'oppskrifter'}
  </p>

  <div class="recipes-grid">
    {
      recipes.map((recipe: any) => (
        <RecipeCard
          tittel={recipe.data.tittel}
          slug={recipe.id}
          kategori={recipe.data.kategori}
          tags={recipe.data.tags}
        />
      ))
    }
  </div>
</BaseLayout>

<style>
  .back {
    font-size: 0.9rem;
    display: inline-block;
    margin-bottom: 0.5rem;
  }

  h1 {
    margin-bottom: 0.25rem;
  }

  .count {
    color: var(--color-muted);
    font-family: var(--font-handwritten);
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }

  .recipes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }
</style>
